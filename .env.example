
# Discord webhook URLs (one per channel)
BROAD_WEBHOOK_URL=
PRIORITY_WEBHOOK_URL=

# Optional: post into specific existing threads instead of creating new threads each run
# To get a thread ID: open the thread in Discord, copy the URL, the last number is the ID
BROAD_THREAD_ID=
PRIORITY_THREAD_ID=

# Optional: GitHub personal access token for higher API rate limits
GITHUB_TOKEN=

# ColorStack Slack — see README for how to get these
SLACK_USER_TOKEN=xoxp-your-user-token-here
# Channel IDs (not names) — right-click channel > Copy Link, the ID is the last segment
SLACK_CHANNEL_OPPORTUNITIES_ID=C0000000000
SLACK_CHANNEL_FT_ID=C0000000000
